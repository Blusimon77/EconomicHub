# ============================================================
# Social Media Manager — NestJS — Environment Variables
# Copy this file to .env and fill in your values.
# ============================================================

# ------------------------------------------------------------
# Database (required)
# Vercel Postgres connection string, or a local PostgreSQL URI.
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?sslmode=require
# ------------------------------------------------------------
DATABASE_URL=postgresql://user:password@localhost:5432/social_media_manager

# ------------------------------------------------------------
# AI — Primary provider
# "anthropic" uses Claude; "openai" uses the compatible endpoint below.
# ------------------------------------------------------------
AI_PRIMARY_PROVIDER=anthropic

# Anthropic / Claude
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# OpenAI-compatible (local Qwen fallback or any OpenAI-compatible server)
OPENAI_COMPATIBLE_BASE_URL=http://10.99.97.102:8080/v1
OPENAI_COMPATIBLE_API_KEY=none
OPENAI_COMPATIBLE_MODEL=Qwen3.5-122B

# ------------------------------------------------------------
# LinkedIn
# ------------------------------------------------------------
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
LINKEDIN_ACCESS_TOKEN=
LINKEDIN_ORGANIZATION_ID=

# ------------------------------------------------------------
# Facebook / Instagram Graph API
# ------------------------------------------------------------
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
FACEBOOK_ACCESS_TOKEN=
FACEBOOK_PAGE_ID=
INSTAGRAM_BUSINESS_ACCOUNT_ID=
FACEBOOK_API_VERSION=v19.0

# ------------------------------------------------------------
# Web search
# ------------------------------------------------------------
TAVILY_API_KEY=

# ------------------------------------------------------------
# Dashboard authentication
# DASHBOARD_PASSWORD: leave empty to disable login (dev only).
# SESSION_SECRET: must be at least 16 characters. Change from default!
# CRON_SECRET: shared secret for Vercel Cron webhook endpoints.
# ------------------------------------------------------------
DASHBOARD_PASSWORD=
SESSION_SECRET=change_this_secret_key_min_16_chars
CRON_SECRET=

# ------------------------------------------------------------
# Server
# 8001 to avoid clash with Python dashboard on 8000.
# ------------------------------------------------------------
DASHBOARD_HOST=127.0.0.1
DASHBOARD_PORT=8001

# ------------------------------------------------------------
# Scheduling — comma-separated HH:MM post times per platform
# ------------------------------------------------------------
LINKEDIN_POST_TIMES=09:00,12:00,17:00
FACEBOOK_POST_TIMES=10:00,14:00,19:00
INSTAGRAM_POST_TIMES=08:00,13:00,18:00

# ------------------------------------------------------------
# Monitoring
# ------------------------------------------------------------
MONITOR_INTERVAL_MINUTES=15
COMPANY_NAME=Azienda
BRAND_KEYWORDS=
