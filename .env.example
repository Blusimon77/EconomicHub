# ── AI Models ──────────────────────────────────────────────
ANTHROPIC_API_KEY=your_anthropic_api_key_here
ANTHROPIC_MODEL=claude-sonnet-4-6

# OpenAI-compatible API (v1)
OPENAI_COMPATIBLE_BASE_URL=https://api.openai.com/v1
OPENAI_COMPATIBLE_API_KEY=your_openai_api_key_here
OPENAI_COMPATIBLE_MODEL=gpt-4o

# Primary AI provider: "anthropic" or "openai"
AI_PRIMARY_PROVIDER=anthropic

# ── LinkedIn ────────────────────────────────────────────────
LINKEDIN_CLIENT_ID=your_linkedin_client_id
LINKEDIN_CLIENT_SECRET=your_linkedin_client_secret
LINKEDIN_ACCESS_TOKEN=your_linkedin_access_token
LINKEDIN_ORGANIZATION_ID=your_linkedin_org_id

# ── Facebook / Instagram ────────────────────────────────────
FACEBOOK_APP_ID=your_facebook_app_id
FACEBOOK_APP_SECRET=your_facebook_app_secret
FACEBOOK_ACCESS_TOKEN=your_facebook_page_access_token
FACEBOOK_PAGE_ID=your_facebook_page_id
INSTAGRAM_BUSINESS_ACCOUNT_ID=your_instagram_business_account_id

# ── Web Search (Tavily — free tier: tavily.com) ─────────────
TAVILY_API_KEY=tvly-your_key_here

# ── Dashboard ───────────────────────────────────────────────
DASHBOARD_HOST=127.0.0.1
DASHBOARD_PORT=8000
DASHBOARD_SECRET_KEY=change_this_secret_key

# ── Database ────────────────────────────────────────────────
DATABASE_URL=sqlite:///./storage/social_manager.db

# ── Scheduling ──────────────────────────────────────────────
# Orari ottimali di pubblicazione (formato HH:MM, separati da virgola)
LINKEDIN_POST_TIMES=09:00,12:00,17:00
FACEBOOK_POST_TIMES=10:00,14:00,19:00
INSTAGRAM_POST_TIMES=08:00,13:00,18:00

# ── Monitoring ──────────────────────────────────────────────
MONITOR_INTERVAL_MINUTES=15
COMPANY_NAME=Nome Azienda
BRAND_KEYWORDS=keyword1,keyword2,keyword3
